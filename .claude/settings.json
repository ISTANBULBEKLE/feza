{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo *)",
      "Bash(gh secret list)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git push *)",
      "Bash(curl http://localhost:*)",
      "Bash(curl https://images-api.nasa.gov/*)",
      "Bash(curl https://api.nasa.gov/neo/*)",
      "Bash(claude mcp list)",
      "Bash(node -v)",
      "Bash(npx --yes create-next-app@latest *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(gh pr merge *)",
      "Bash(git push --force *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.tsx|*.ts|*.scss) npx --no-install eslint --max-warnings 0 --no-warn-ignored \"$f\" 2>&1 ;; esac; true",
            "timeout": 30,
            "statusMessage": "Linting changed file"
          }
        ]
      }
    ]
  }
}
