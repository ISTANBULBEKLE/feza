{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo *)",
      "Bash(gh secret list)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git push *)",
      "Bash(curl http://localhost:*)",
      "Bash(curl https://images-api.nasa.gov/*)",
      "Bash(node -v)",
      "Bash(npx --yes create-next-app@latest *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(gh pr merge *)",
      "Bash(git push --force *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git reset --hard *)"
    ]
  }
}
