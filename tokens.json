{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "feza design tokens in W3C DTCG format. Import via Tokens Studio for Figma (Tools → Import → JSON). Source of truth: src/app/globals.scss and the per-component .module.scss files. Snapshot generated for the canonical state of the feza repo.",

  "color": {
    "$description": "Color tokens. The dark theme is the canonical/default. Light overrides only the surface/text/border family — accent and danger are theme-invariant.",
    "dark": {
      "background":     { "$type": "color", "$value": "#0B0D12" },
      "foreground":     { "$type": "color", "$value": "#E7EAF2" },
      "muted":          { "$type": "color", "$value": "#8B93A7" },
      "surface":        { "$type": "color", "$value": "#11151D" },
      "surface-2":      { "$type": "color", "$value": "#1A2030" },
      "border":         { "$type": "color", "$value": "#232A3A" },
      "accent":         { "$type": "color", "$value": "#6CB4FF" },
      "accent-strong":  { "$type": "color", "$value": "#9AD0FF" },
      "danger":         { "$type": "color", "$value": "#FF7A7A" },
      "on-accent":      { "$type": "color", "$value": "#06121F", "$description": "Text on filled accent (Button primary, active Chip)." }
    },
    "light": {
      "background":     { "$type": "color", "$value": "#F7F8FB" },
      "foreground":     { "$type": "color", "$value": "#0B0D12" },
      "muted":          { "$type": "color", "$value": "#5B6478" },
      "surface":        { "$type": "color", "$value": "#FFFFFF" },
      "surface-2":      { "$type": "color", "$value": "#EEF1F6" },
      "border":         { "$type": "color", "$value": "#D8DDE7" },
      "accent":         { "$type": "color", "$value": "#6CB4FF" },
      "accent-strong":  { "$type": "color", "$value": "#9AD0FF" },
      "danger":         { "$type": "color", "$value": "#FF7A7A" },
      "on-accent":      { "$type": "color", "$value": "#06121F" }
    }
  },

  "space": {
    "$description": "Spacing scale extracted from gap/padding/margin in SCSS modules.",
    "0-5":  { "$type": "dimension", "$value": "4px" },
    "1":    { "$type": "dimension", "$value": "6px" },
    "1-5":  { "$type": "dimension", "$value": "8px" },
    "2":    { "$type": "dimension", "$value": "10px" },
    "2-5":  { "$type": "dimension", "$value": "12px" },
    "3":    { "$type": "dimension", "$value": "14px" },
    "3-5":  { "$type": "dimension", "$value": "16px" },
    "4":    { "$type": "dimension", "$value": "18px" },
    "4-5":  { "$type": "dimension", "$value": "20px" },
    "5":    { "$type": "dimension", "$value": "22px" },
    "6":    { "$type": "dimension", "$value": "24px" },
    "8":    { "$type": "dimension", "$value": "32px" },
    "12":   { "$type": "dimension", "$value": "48px" },
    "20":   { "$type": "dimension", "$value": "80px" }
  },

  "radius": {
    "xs":   { "$type": "dimension", "$value": "4px",   "$description": "Inline <code> background." },
    "sm":   { "$type": "dimension", "$value": "6px",   "$description": "Clear-icon hit area." },
    "md":   { "$type": "dimension", "$value": "10px",  "$description": "Buttons, selects, inputs, nav links." },
    "lg":   { "$type": "dimension", "$value": "16px",  "$description": "Cards (Photo, Skeleton, landing)." },
    "pill": { "$type": "dimension", "$value": "999px", "$description": "Chips." }
  },

  "shadow": {
    "md": {
      "$type": "shadow",
      "$value": {
        "color":   "#00000059",
        "offsetX": "0px",
        "offsetY": "6px",
        "blur":    "24px",
        "spread":  "0px"
      },
      "$description": "Resting card elevation (rgba(0,0,0,0.35))."
    },
    "card-hover": {
      "$type": "shadow",
      "$value": {
        "color":   "#00000066",
        "offsetX": "0px",
        "offsetY": "10px",
        "blur":    "28px",
        "spread":  "0px"
      },
      "$description": "PhotoCard:hover (rgba(0,0,0,0.4))."
    }
  },

  "font": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"],
        "$description": "Use Inter in Figma master library."
      }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":    { "$type": "fontWeight", "$value": 700 }
    },
    "size": {
      "tag":      { "$type": "dimension", "$value": "11px" },
      "xs":       { "$type": "dimension", "$value": "12px" },
      "sm":       { "$type": "dimension", "$value": "13px" },
      "body":     { "$type": "dimension", "$value": "14px" },
      "card-h3":  { "$type": "dimension", "$value": "15px" },
      "wordmark": { "$type": "dimension", "$value": "16px" },
      "card-h2":  { "$type": "dimension", "$value": "22px" },
      "h1-min":   { "$type": "dimension", "$value": "24px",
                    "$description": "Heading L lower bound — Explore h1 clamp(24px,4vw,36px)." },
      "h1-max":   { "$type": "dimension", "$value": "36px",
                    "$description": "Heading L upper bound." },
      "display-min": { "$type": "dimension", "$value": "28px",
                       "$description": "Display lower bound — Landing h1 clamp(28px,5vw,44px)." },
      "display-mid": { "$type": "dimension", "$value": "40px",
                       "$description": "APOD title upper bound." },
      "display-max": { "$type": "dimension", "$value": "44px",
                       "$description": "Landing display upper bound." }
    },
    "lineHeight": {
      "tight":   { "$type": "number", "$value": 1.0 },
      "display": { "$type": "number", "$value": 1.1 },
      "h2":      { "$type": "number", "$value": 1.2 },
      "card":    { "$type": "number", "$value": 1.3 },
      "body":    { "$type": "number", "$value": 1.5 }
    },
    "letterSpacing": {
      "display":  { "$type": "dimension", "$value": "-0.01em" },
      "label":    { "$type": "dimension", "$value": "0.06em" },
      "eyebrow":  { "$type": "dimension", "$value": "0.08em" },
      "fallback": { "$type": "dimension", "$value": "0.1em",
                    "$description": "PhotoCard fallback text (IMAGE/VIDEO/AUDIO)." }
    }
  },

  "typography": {
    "$description": "Composite text styles combining family / size / line / letter / weight.",
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily":   "{font.family.sans}",
        "fontWeight":   "{font.weight.regular}",
        "fontSize":     "{font.size.display-max}",
        "lineHeight":   "{font.lineHeight.display}",
        "letterSpacing": "{font.letterSpacing.display}"
      },
      "$description": "Hero / page title. In code: clamp(28px, 5vw, 44px)."
    },
    "heading-l": {
      "$type": "typography",
      "$value": {
        "fontFamily":   "{font.family.sans}",
        "fontWeight":   "{font.weight.regular}",
        "fontSize":     "{font.size.h1-max}",
        "lineHeight":   "{font.lineHeight.display}"
      },
      "$description": "Section heading on Explore. clamp(24px, 4vw, 36px)."
    },
    "heading-m": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize":   "{font.size.card-h2}",
        "lineHeight": "{font.lineHeight.h2}"
      },
      "$description": "Landing card h2."
    },
    "heading-s": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize":   "{font.size.card-h3}",
        "lineHeight": "{font.lineHeight.card}"
      },
      "$description": "PhotoCard h3."
    },
    "wordmark": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.family.sans}",
        "fontWeight":    "{font.weight.bold}",
        "fontSize":      "{font.size.wordmark}",
        "lineHeight":    "{font.lineHeight.tight}",
        "letterSpacing": "{font.letterSpacing.display}"
      },
      "$description": "Header brand wordmark."
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize":   "{font.size.body}",
        "lineHeight": "{font.lineHeight.body}"
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize":   "{font.size.sm}",
        "lineHeight": "{font.lineHeight.body}"
      },
      "$description": "Footer, status row, back link, lead text."
    },
    "body-xs": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.regular}",
        "fontSize":   "{font.size.xs}",
        "lineHeight": "{font.lineHeight.body}"
      },
      "$description": "Chip text, PhotoCard meta."
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.family.sans}",
        "fontWeight":    "{font.weight.regular}",
        "fontSize":      "{font.size.xs}",
        "lineHeight":    "{font.lineHeight.body}",
        "letterSpacing": "{font.letterSpacing.label}",
        "textCase":      "uppercase"
      },
      "$description": "Form labels above Select / SearchBox."
    },
    "eyebrow": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.family.sans}",
        "fontWeight":    "{font.weight.regular}",
        "fontSize":      "{font.size.sm}",
        "lineHeight":    "{font.lineHeight.tight}",
        "letterSpacing": "{font.letterSpacing.eyebrow}",
        "textCase":      "uppercase"
      },
      "$description": "Landing eyebrow ('feza · live demo app')."
    },
    "tag": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.family.sans}",
        "fontWeight":    "{font.weight.regular}",
        "fontSize":      "{font.size.tag}",
        "lineHeight":    "{font.lineHeight.tight}",
        "letterSpacing": "{font.letterSpacing.eyebrow}",
        "textCase":      "uppercase"
      },
      "$description": "Landing card tag, APOD tag."
    },
    "button": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.semibold}",
        "fontSize":   "{font.size.body}",
        "lineHeight": "{font.lineHeight.body}"
      }
    }
  },

  "motion": {
    "fast":  { "$type": "duration", "$value": "60ms",   "$description": "Button :active press." },
    "base":  { "$type": "duration", "$value": "120ms",  "$description": "All hover/focus." },
    "shimmer": { "$type": "duration", "$value": "1400ms", "$description": "SkeletonCard shimmer cycle." },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.25, 0.1, 0.25, 1.0], "$description": "CSS ease." },
      "linear":  { "$type": "cubicBezier", "$value": [0.0, 0.0, 1.0, 1.0],   "$description": "Used by shimmer." }
    }
  },

  "layout": {
    "max-width": { "$type": "dimension", "$value": "1100px", "$description": "Content max-width (--maxw)." },
    "main-padding-top":    { "$type": "dimension", "$value": "32px" },
    "main-padding-x":      { "$type": "dimension", "$value": "20px" },
    "main-padding-bottom": { "$type": "dimension", "$value": "80px" },
    "header-height-approx": { "$type": "dimension", "$value": "52px" },
    "header-blur":         { "$type": "dimension", "$value": "12px" },
    "z-header":            { "$type": "number",    "$value": 10 },
    "grid": {
      "photo-min":   { "$type": "dimension", "$value": "240px",
                       "$description": "PhotoGrid auto-fill minmax(240px, 1fr)." },
      "card-min":    { "$type": "dimension", "$value": "260px",
                       "$description": "Landing cards auto-fit minmax(260px, 1fr)." },
      "control-min": { "$type": "dimension", "$value": "160px",
                       "$description": "Explore controls auto-fit minmax(160px, 1fr)." }
    },
    "frames": {
      "$description": "Recommended Figma frame widths.",
      "desktop":  { "$type": "dimension", "$value": "1440px" },
      "medium":   { "$type": "dimension", "$value": "1024px" },
      "tablet":   { "$type": "dimension", "$value": "768px" },
      "mobile":   { "$type": "dimension", "$value": "390px" }
    }
  },

  "components": {
    "button": {
      "padding-y": "{space.2}",
      "padding-x": "{space.3-5}",
      "radius":    "{radius.md}",
      "gap":       "{space.1-5}"
    },
    "select": {
      "padding-top":    "{space.2}",
      "padding-right":  "{space.8}",
      "padding-bottom": "{space.2}",
      "padding-left":   "{space.2-5}",
      "radius":         "{radius.md}",
      "label-gap":      "{space.1}"
    },
    "searchbox": {
      "padding-top":    "{space.2}",
      "padding-right":  "{space.8}",
      "padding-bottom": "{space.2}",
      "padding-left":   { "$type": "dimension", "$value": "34px",
                          "$description": "Reserves room for the ⌕ icon." },
      "radius":         "{radius.md}",
      "icon-left":      "{space.2-5}",
      "clear-right":    "{space.1-5}",
      "clear-size":     { "$type": "dimension", "$value": "24px" }
    },
    "chip": {
      "padding-y": "{space.1}",
      "padding-x": "{space.2-5}",
      "radius":    "{radius.pill}",
      "gap":       "{space.1}",
      "font-size": "{font.size.xs}"
    },
    "photocard": {
      "radius":          "{radius.lg}",
      "media-aspect":    "16/10",
      "body-padding-top":    "{space.3}",
      "body-padding-x":      "{space.3-5}",
      "body-padding-bottom": "{space.4}",
      "body-gap":            "{space.1}",
      "title-size":          "{font.size.card-h3}",
      "title-line":          "{font.lineHeight.card}",
      "meta-size":           "{font.size.xs}",
      "desc-size":           "{font.size.sm}",
      "desc-clamp-lines":    { "$type": "number", "$value": 3 }
    },
    "skeletoncard": {
      "radius":         "{radius.lg}",
      "media-aspect":   "16/10",
      "body-padding-top":    "{space.3}",
      "body-padding-x":      "{space.3-5}",
      "body-padding-bottom": "{space.4}",
      "body-gap":            "{space.1-5}",
      "line-radius":   "{space.1}"
    },
    "header": {
      "padding-y":   "{space.2-5}",
      "padding-x":   "{layout.main-padding-x}",
      "gap":         "{space.3-5}",
      "blur":        "{layout.header-blur}",
      "bg-opacity":  { "$type": "number", "$value": 0.85 },
      "nav-gap":     "{space.0-5}",
      "nav-link-padding-y": "{space.1}",
      "nav-link-padding-x": "{space.2-5}"
    },
    "footer": {
      "padding":  "{layout.main-padding-x}",
      "gap":      "{space.2-5}",
      "font":     "{typography.body-sm}",
      "inline-gap": "{space.1}"
    },
    "panel": {
      "gap":       "{space.3}",
      "controls-gap": "{space.2-5}",
      "controls-min": "{layout.grid.control-min}",
      "status-min-height": { "$type": "dimension", "$value": "18px" }
    },
    "landing-card": {
      "radius":  "{radius.lg}",
      "padding": "{space.4-5}",
      "tag-margin-bottom":   "{space.2}",
      "title-margin-bottom": "{space.1-5}",
      "title-size":          "{font.size.card-h2}",
      "body-size":           "{font.size.body}"
    }
  },

  "icon": {
    "$description": "Inline Unicode glyphs used as icons. No icon font, no SVG sprite.",
    "brand-mark":  { "$type": "string", "$value": "✦", "$description": "✦ U+2726" },
    "search":      { "$type": "string", "$value": "⌕", "$description": "⌕ U+2315" },
    "clear":       { "$type": "string", "$value": "×", "$description": "× U+00D7" },
    "right-arrow": { "$type": "string", "$value": "→", "$description": "→ U+2192" },
    "separator":   { "$type": "string", "$value": "·", "$description": "· U+00B7" }
  },

  "presets": {
    "$description": "Static lists used by Epic 1 controls.",
    "topics": {
      "$type": "array",
      "$value": [
        { "label": "Mars Rover",          "value": "mars rover" },
        { "label": "Apollo Missions",     "value": "apollo" },
        { "label": "Hubble",              "value": "hubble" },
        { "label": "James Webb (JWST)",   "value": "james webb" },
        { "label": "ISS",                 "value": "international space station" },
        { "label": "Earth from Orbit",    "value": "earth from orbit" }
      ]
    },
    "media-types": {
      "$type": "array",
      "$value": ["image", "video", "audio"]
    }
  }
}
